@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Crear Curso";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="CreateCurso" method="post">
    <div class="form-group">
        <label asp-for="Codigo"></label>
        <input asp-for="Codigo" class="form-control" />
        <span asp-validation-for="Codigo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Creditos"></label>
        <input asp-for="Creditos" class="form-control" />
        <span asp-validation-for="Creditos" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="CupoMaximo"></label>
        <input asp-for="CupoMaximo" class="form-control" />
        <span asp-validation-for="CupoMaximo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="HorarioInicio"></label>
        <input asp-for="HorarioInicio" type="time" class="form-control" />
        <span asp-validation-for="HorarioInicio" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="HorarioFin"></label>
        <input asp-for="HorarioFin" type="time" class="form-control" />
        <span asp-validation-for="HorarioFin" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Crear</button>
    <a asp-action="Cursos" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
