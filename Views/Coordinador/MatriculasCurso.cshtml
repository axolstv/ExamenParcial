@model PortalAcademico.Models.Curso
@{
    ViewData["Title"] = "Matrículas del curso " + Model.Nombre;
}

<h2>@ViewData["Title"]</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Fecha de registro</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Matriculas != null && Model.Matriculas.Any())
        {
            foreach (var matricula in Model.Matriculas)
            {
                <tr>
                    <td>@matricula.UsuarioId</td>
                    <td>@matricula.FechaRegistro.ToString("g")</td>
                    <td>@matricula.Estado</td>
                    <td>
                        @if (matricula.Estado == PortalAcademico.Models.EstadoMatricula.Pendiente)
                        {
                            <form asp-controller="Coordinador" asp-action="ConfirmarMatricula" method="post" style="display:inline">
                                <input type="hidden" name="matriculaId" value="@matricula.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Confirmar</button>
                            </form>
                            <form asp-controller="Coordinador" asp-action="CancelarMatricula" method="post" style="display:inline">
                                <input type="hidden" name="matriculaId" value="@matricula.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">Sin acciones</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">No hay matrículas registradas.</td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Coordinador" asp-action="Cursos" class="btn btn-secondary">Volver a cursos</a>
