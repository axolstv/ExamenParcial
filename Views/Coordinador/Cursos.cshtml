@model IEnumerable<PortalAcademico.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador - Cursos";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="CreateCurso" class="btn btn-success">Crear Nuevo Curso</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupo Máximo</th>
            <th>Horario</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var curso in Model)
    {
        <tr>
            <td>@curso.Codigo</td>
            <td>@curso.Nombre</td>
            <td>@curso.Creditos</td>
            <td>@curso.CupoMaximo</td>
            <td>@curso.HorarioInicio.ToString(@"hh\:mm") - @curso.HorarioFin.ToString(@"hh\:mm")</td>
            <td>@(curso.Activo ? "Sí" : "No")</td>
            <td>
                <a asp-action="EditCurso" asp-route-id="@curso.Id" class="btn btn-primary btn-sm">Editar</a>
                <form asp-action="DesactivarCurso" asp-route-id="@curso.Id" method="post" style="display:inline">
                    <button type="submit" class="btn btn-danger btn-sm">@((curso.Activo) ? "Desactivar" : "Activar")</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
